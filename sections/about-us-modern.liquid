  ],
  "presets": [
    {
      "name": "About us modern",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" },
        { "type": "value" },
        { "type": "value" },
        { "type": "value" },
        { "type": "milestone" },
        { "type": "milestone" },
        { "type": "milestone" },
        { "type": "team_member" },
