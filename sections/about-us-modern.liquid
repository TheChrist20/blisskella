          "default": "Expanded delivery coverage and improved customer support operations."
        }
      ]
    },
    {
      "type": "team_member",
      "name": "Team member",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
