{{ 'faq-modern.css' | asset_url | stylesheet_tag }}

<div
  id="faq-{{ section.id }}" 
  class="
    faq
    faq-modern
    {{ section.settings.bg_color }} 
    {{ section.settings.bg_gradient }}
    {{ section.settings.text_color }}
    {{ section.settings.border_top_width | prepend: 'border-top-' }}
    {{ section.settings.border_bottom_width | prepend: 'border-bottom-' }}
    {{ section.settings.border_color }} 
    {{ section.settings.pt | prepend: 'pt-' }} 
    {{ section.settings.pb | prepend: 'pb-' }}
  "
  style="
    --bs-bg-opacity: {{ section.settings.bg_opacity | append: '%' }};
    --bs-border-opacity: {{ section.settings.border_opacity | append: '%' }};
  ">
  <div 
    class="container" 
    style="max-width: {{ section.settings.container_max_width }}px">
    <div class="row align-items-center faq-modern__layout">
      <div class="col-desktop-8 faq-modern__intro-col">
        {% if section.settings.eyebrow != blank %}
          <p class="faq-modern__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% render 'section-header' %}
      </div>
      <div class="col-desktop-10 faq-modern__accordion-col">
        <div 
          id="faq-accordion-{{ section.id }}" 
          class="accordion faq-modern__accordion">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% liquid
                assign question_number = forloop.index
                if forloop.index < 10
                  assign question_number = forloop.index | prepend: '0'
                endif
              %}
              <div 
                class="accordion-item" 
                data-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}>
                <h3 
                  id="faq-accordion-{{ section.id }}-heading-{{ forloop.index }}" 
                  class="accordion-header">
                  <button 
                    class="accordion-button {% unless section.settings.open_first_item == true and forloop.first %}collapsed{% endunless %}" 
                    type="button" 
                    data-bs-toggle="collapse" 
                    data-bs-target="#faq-accordion-{{ section.id }}-collapse-{{ forloop.index }}" 
                    aria-expanded="{% if section.settings.open_first_item == true and forloop.first %}true{% else %}false{% endif %}" 
                    aria-controls="faq-accordion-{{ section.id }}-collapse-{{ forloop.index }}">
                    <span class="faq-modern__question-id">{{ question_number }}</span>
                    <span class="faq-modern__question-text">{{ block.settings.title | escape }}</span>
                  </button>
                </h3>
                <div 
                  id="faq-accordion-{{ section.id }}-collapse-{{ forloop.index }}" 
                  class="accordion-collapse collapse {% if section.settings.open_first_item == true and forloop.first %}show{% endif %}" 
                  aria-labelledby="faq-accordion-{{ section.id }}-heading-{{ forloop.index }}" 
                  data-bs-parent="#faq-accordion-{{ section.id }}">
                  <div class="accordion-body rte">
                    {{ block.settings.description }}
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="accordion-item">
              <h3 id="faq-accordion-{{ section.id }}-heading-fallback-1" class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq-accordion-{{ section.id }}-collapse-fallback-1" aria-expanded="true" aria-controls="faq-accordion-{{ section.id }}-collapse-fallback-1">
                  <span class="faq-modern__question-id">01</span>
                  <span class="faq-modern__question-text">How long does shipping take?</span>
                </button>
              </h3>
              <div id="faq-accordion-{{ section.id }}-collapse-fallback-1" class="accordion-collapse collapse show" aria-labelledby="faq-accordion-{{ section.id }}-heading-fallback-1" data-bs-parent="#faq-accordion-{{ section.id }}">
                <div class="accordion-body rte"><p>Delivery timelines vary by location, and most orders arrive within 7-21 business days.</p></div>
              </div>
            </div>

            <div class="accordion-item">
              <h3 id="faq-accordion-{{ section.id }}-heading-fallback-2" class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-accordion-{{ section.id }}-collapse-fallback-2" aria-expanded="false" aria-controls="faq-accordion-{{ section.id }}-collapse-fallback-2">
                  <span class="faq-modern__question-id">02</span>
                  <span class="faq-modern__question-text">Can I track my order?</span>
                </button>
              </h3>
              <div id="faq-accordion-{{ section.id }}-collapse-fallback-2" class="accordion-collapse collapse" aria-labelledby="faq-accordion-{{ section.id }}-heading-fallback-2" data-bs-parent="#faq-accordion-{{ section.id }}">
                <div class="accordion-body rte"><p>Yes. Once your order is shipped, tracking details are sent to your email.</p></div>
              </div>
            </div>

            <div class="accordion-item">
              <h3 id="faq-accordion-{{ section.id }}-heading-fallback-3" class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-accordion-{{ section.id }}-collapse-fallback-3" aria-expanded="false" aria-controls="faq-accordion-{{ section.id }}-collapse-fallback-3">
                  <span class="faq-modern__question-id">03</span>
                  <span class="faq-modern__question-text">Can I modify or cancel my order?</span>
                </button>
              </h3>
              <div id="faq-accordion-{{ section.id }}-collapse-fallback-3" class="accordion-collapse collapse" aria-labelledby="faq-accordion-{{ section.id }}-heading-fallback-3" data-bs-parent="#faq-accordion-{{ section.id }}">
                <div class="accordion-body rte"><p>Orders can usually be changed or canceled within 24 hours of purchase.</p></div>
              </div>
            </div>

            <div class="accordion-item">
              <h3 id="faq-accordion-{{ section.id }}-heading-fallback-4" class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-accordion-{{ section.id }}-collapse-fallback-4" aria-expanded="false" aria-controls="faq-accordion-{{ section.id }}-collapse-fallback-4">
                  <span class="faq-modern__question-id">04</span>
                  <span class="faq-modern__question-text">What if I receive a damaged item?</span>
                </button>
              </h3>
              <div id="faq-accordion-{{ section.id }}-collapse-fallback-4" class="accordion-collapse collapse" aria-labelledby="faq-accordion-{{ section.id }}-heading-fallback-4" data-bs-parent="#faq-accordion-{{ section.id }}">
                <div class="accordion-body rte"><p>Contact support with photos within 48 hours of delivery so we can resolve it quickly.</p></div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% if request.design_mode %}
  <script>
    document.addEventListener('shopify:block:select', (event) => {
      const faq = event.target.closest('#faq-{{ section.id }}')
    
      if (faq) {
        const index = Number(event.target.dataset.index) + 1
        const collapseEl = faq.querySelector(`#faq-accordion-{{ section.id }}-collapse-${index}`)
        const bsCollapse = bootstrap.Collapse.getOrCreateInstance(collapseEl)
        bsCollapse.show()
      }
    })
  </script>
{% endif %}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.title | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.description | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    {% else %}
      {
        "@type": "Question",
        "name": "How long does shipping take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Delivery timelines vary by location, and most orders arrive within 7-21 business days."
        }
      },
      {
        "@type": "Question",
        "name": "Can I track my order?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Once your order is shipped, tracking details are sent to your email."
        }
      },
      {
        "@type": "Question",
        "name": "Can I modify or cancel my order?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Orders can usually be changed or canceled within 24 hours of purchase."
        }
      }
    {% endif %}
    ]
  }
</script>

{% schema %}
{
  "name": "FAQs",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background color",
      "default": "bg-body",
      "options": [
        { "value": "bg-primary", "label": "Primary" },
        { "value": "bg-secondary", "label": "Secondary" },
        { "value": "bg-body", "label": "Body" },
        { "value": "bg-white", "label": "White" }
      ]
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "bg_gradient",
      "label": "Background gradient",
      "options": [
        { "value": "bg-gradient", "label": "Yes" },
        { "value": "", "label": "No" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "default": "text-body",
      "options": [
        { "value": "text-primary", "label": "Primary" },
        { "value": "text-secondary", "label": "Secondary" },
        { "value": "text-body", "label": "Body" },
        { "value": "text-white", "label": "White" }
      ]
    },
    {
      "type": "range",
      "id": "border_top_width",
      "label": "Border top width",
      "default": 0,
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Border bottom width",
      "default": 0,
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "border_color",
      "label": "Border color",
      "default": "border-body",
      "options": [
        { "value": "border-primary", "label": "Primary" },
        { "value": "border-secondary", "label": "Secondary" },
        { "value": "border-body", "label": "Body" },
        { "value": "border-white", "label": "White" }
      ]
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "Border opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "container_max_width",
      "label": "Container max-width (px)",
      "info": "Leave empty to use the global container width"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "label": "Open first item by default",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Support center"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "header_title",
      "label": "Title",
      "default": "FAQs"
    },
    {
      "type": "select",
      "id": "header_title_font_size",
      "label": "Title font-size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "richtext",
      "id": "header_description",
